# UFO production runtime environment example.
# Use this as a values/env reference for Kubernetes or your deploy platform.
# Do not commit populated secrets.

# Supabase Postgres. Prefer the direct connection. If the deploy host is
# IPv4-only, use Supavisor session mode. Do not use transaction mode; UFO
# keeps long-lived PostgreSQL sessions for LISTEN/NOTIFY.
PG_HOST=db.your-project-ref.supabase.co
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=replace_me
PG_DATABASE=postgres
PG_SSLMODE=require

# The API reads this value. Build it from the PG_* values above in your deploy
# system, or set it directly as a secret.
UFO_HUB_DATABASE_URL=host=db.your-project-ref.supabase.co port=5432 user=postgres password=replace_me dbname=postgres sslmode=require

UFO_HUB_URL=https://api.ufo.example.com
UFO_HUB_WEB_URL=https://ufo.example.com
UFO_HUB_ALLOWED_ORIGINS=https://ufo.example.com
UFO_HUB_SECURE_COOKIES=1
# Base64 Ed25519 seed for EdDSA JWTs; generate with: openssl rand -base64 32
UFO_HUB_JWT_PRIVATE_KEY=replace_with_base64_ed25519_seed
UFO_HUB_JWT_ACCESS_SECONDS=3600
UFO_HUB_JWT_ISSUER=ufo-hub
UFO_HUB_JWT_AUDIENCE=ufo-api

# Public beta defaults.
UFO_HUB_MIN_ROVER_VERSION=0.3.1
UFO_HUB_MAX_ROVER_VERSION=

# Hub tuning.
UFO_HUB_RUN_LEASE_SECONDS=30
UFO_HUB_LONGPOLL_SECONDS=25
UFO_HUB_MAX_SUB_OPERATIONS=8
UFO_HUB_ROVER_ONLINE_WINDOW_SECONDS=60
UFO_HUB_ROUTINE_SCHEDULER_SECONDS=60

# Storage: local filesystem backend. Mount durable writable storage here.
UFO_HUB_ASSET_BACKEND=local
UFO_HUB_ASSET_LOCAL_ROOT=/var/lib/ufo/assets
UFO_HUB_ASSET_UPLOAD_MAX_BYTES=26214400
UFO_HUB_ASSET_UPLOAD_ALLOWED_CONTENT_TYPES=
UFO_HUB_ASSET_SIGNED_URL_SECONDS=900

# Storage: S3-compatible object storage.
# Uncomment this common block, then pick the provider endpoint/region below.
# UFO_HUB_ASSET_BACKEND=s3
# UFO_HUB_ASSET_S3_BUCKET=ufo-assets-prod
# UFO_HUB_ASSET_S3_ACCESS_KEY_ID=replace_me
# UFO_HUB_ASSET_S3_SECRET_ACCESS_KEY=replace_me
# UFO_HUB_ASSET_S3_PREFIX=prod

# AWS S3.
# UFO_HUB_ASSET_S3_REGION=us-east-1

# Cloudflare R2.
# UFO_HUB_ASSET_S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
# UFO_HUB_ASSET_S3_REGION=auto

# MinIO (path-style).
# UFO_HUB_ASSET_S3_ENDPOINT=https://minio.example.com
# UFO_HUB_ASSET_S3_REGION=us-east-1
# UFO_HUB_ASSET_S3_PATH_STYLE=1

# Storage: Google Cloud Storage.
# UFO_HUB_ASSET_BACKEND=gcs
# UFO_HUB_ASSET_GCS_BUCKET=ufo-assets-prod
# GCS currently signs upload/file URLs locally, so use service-account JSON
# with a private key. Workload identity without IAM signBlob is not enough
# yet.
# UFO_HUB_ASSET_GCS_CREDENTIALS_FILE=/run/secrets/gcs-service-account.json
# UFO_HUB_ASSET_GCS_CREDENTIALS_JSON=
# UFO_HUB_ASSET_GCS_ENDPOINT=
# UFO_HUB_ASSET_GCS_PREFIX=prod
