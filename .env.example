# Copy to .env and adjust as needed.

# PostgreSQL (matches compose.yaml)
DATABASE_URL=postgres://ufo:ufo@localhost:5432/ufo?sslmode=disable

# Go API server
UFO_API_ADDR=:8080

# Seconds without a heartbeat before the sweeper requeues a run (rover lost).
UFO_RUN_LEASE_SECONDS=30

# How long the rover claim endpoint holds a request waiting for work (long-poll).
UFO_LONGPOLL_SECONDS=25

# Mark the session cookie Secure (set when serving the API over HTTPS).
# UFO_SECURE_COOKIES=1

# Browser origin allowlist for CORS + WebSocket (comma-separated). Unset allows
# same-origin only; set it in production, e.g. https://ufo.example.com
# UFO_WEB_ORIGIN=

# --- web (host dev) ---
# Next proxies /api to the API so the browser is same-origin (cookies work).
API_PROXY_TARGET=http://localhost:8080

# --- rover (host) ---
# Where the rover reaches the API.
UFO_SERVER=http://localhost:8080
# First run only: an enrollment code from the board's Rovers panel ("Add rover"
# or "Reusable enrollment code"). `rover enroll` exchanges it for a per-rover connection token,
# stored (keyed by rover id) in ~/.ufo/rovers.json; later runs need no token.
#   UFO_ENROLLMENT_CODE=...
# (UFO_OUTPOST overrides the rover base dir, default ~/.ufo.)
#
# The Claude adapter shells out to `claude`; the rover inherits this environment.
# On a TLS-inspecting-proxy host, install the proxy CA in the host trust store.
