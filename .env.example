# Copy to .env and adjust as needed.

# Hub database and listen address.
UFO_HUB_DATABASE_URL=postgres://ufo:ufo@localhost:5432/ufo?sslmode=disable
UFO_HUB_BIND=:8080

# Hub origin clients connect to. The rover and web proxy append /v1.
# In Docker the web container points at http://api:8080 (see compose.yaml).
UFO_HUB_URL=http://localhost:8080

# Web UI base URL the Hub advertises for browser approval flows.
# UFO_HUB_WEB_URL=http://localhost:3000

# Browser origin allowlist for CORS + WebSocket (comma-separated). Unset allows
# same-origin only; set it in production, e.g. https://ufo.example.com
# UFO_HUB_ALLOWED_ORIGINS=

# Mark auth cookies Secure (set when serving the API over HTTPS).
# UFO_HUB_SECURE_COOKIES=1

# Access-token signing. Leave unset for local dev; production uses a base64
# Ed25519 seed/private key for EdDSA, e.g. `openssl rand -base64 32`.
# UFO_HUB_JWT_PRIVATE_KEY=
# UFO_HUB_JWT_ACCESS_SECONDS=3600
# UFO_HUB_JWT_ISSUER=ufo-hub
# UFO_HUB_JWT_AUDIENCE=ufo-api

# Rover version gates. Leave max empty to allow newer rovers during public beta.
UFO_HUB_MIN_ROVER_VERSION=0.3.1
# UFO_HUB_MAX_ROVER_VERSION=

# Hub timing and limits.
UFO_HUB_RUN_LEASE_SECONDS=30
UFO_HUB_LONGPOLL_SECONDS=25
UFO_HUB_ROUTINE_SCHEDULER_SECONDS=60
UFO_HUB_ROVER_ONLINE_WINDOW_SECONDS=60
UFO_HUB_MAX_SUB_OPERATIONS=8

# Postgres URL the integration test suite uses (CI sets this; tests skip
# without it).
# UFO_HUB_TEST_DATABASE_URL=postgres://ufo:ufo@localhost:5432/ufo_test?sslmode=disable

# Asset/object storage. Use local for local/dev, s3 for S3-compatible providers,
# or gcs for Google Cloud Storage.
UFO_HUB_ASSET_BACKEND=local
# UFO_HUB_ASSET_LOCAL_ROOT=
# UFO_HUB_ASSET_UPLOAD_MAX_BYTES=26214400
# UFO_HUB_ASSET_UPLOAD_ALLOWED_CONTENT_TYPES=
# UFO_HUB_ASSET_S3_BUCKET=
# UFO_HUB_ASSET_S3_ENDPOINT=
# UFO_HUB_ASSET_S3_REGION=auto
# UFO_HUB_ASSET_S3_ACCESS_KEY_ID=
# UFO_HUB_ASSET_S3_SECRET_ACCESS_KEY=
# UFO_HUB_ASSET_S3_PATH_STYLE=
# UFO_HUB_ASSET_S3_PREFIX=
# UFO_HUB_ASSET_GCS_BUCKET=
# UFO_HUB_ASSET_GCS_CREDENTIALS_FILE=
# If unset, GCS credentials also fall back to GOOGLE_APPLICATION_CREDENTIALS.
# UFO_HUB_ASSET_GCS_CREDENTIALS_JSON=
# UFO_HUB_ASSET_GCS_ENDPOINT=
# UFO_HUB_ASSET_GCS_PREFIX=
# UFO_HUB_ASSET_SIGNED_URL_SECONDS=900

# First run only: an enrollment code from the board's Rovers panel.
# `rover enroll` exchanges it for a per-rover connection token, stored
# (keyed by rover id) in ~/.ufo/rovers.json; later runs need no token.
#   UFO_ROVER_ENROLLMENT_CODE=...
# (UFO_ROVER_CONFIG overrides the enrollment store, default ~/.ufo/rovers.json.)
# (UFO_ROVER_OUTPOST overrides the rover base directory, default ~/.ufo.)
# (UFO_ROVER_UNITS sets how many operations a rover runs at once, default 1.)
# (UFO_ROVER_AUTO_UPGRADE=1 lets a rover install/restart when the Hub
# requires a newer version.)
# (UFO_ROVER_RETRY_SECONDS sets failed-claim retry delay, default 1.)
# (UFO_ROVER_HEARTBEAT_SECONDS sets the run lease-renewal interval, default 5.)
# (UFO_ROVER_ASSET_UPLOAD_MAX_BYTES limits each rover-uploaded referenced file,
# default 104857600.)
# (UFO_ROVER_ASSET_UPLOAD_MAX_FILES limits referenced file uploads per run,
# default 20.)
#
# Pilot adapters shell out to local CLIs; the rover inherits this environment.
# On a TLS-inspecting-proxy host, install the proxy CA in the host trust
# store.
